@page "/chat"
@rendermode InteractiveWebAssembly

<PageTitle>Chat</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h3>Chat</h3>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body" style="height: 400px; overflow-y: auto;" id="chat-messages">
                    @foreach (var message in _messages)
                    {
                        <div class="mb-2 d-flex @(message.IsUser ? "justify-content-end" : "justify-content-start")">
                            <div class="chat-bubble @(message.IsUser ? "chat-bubble--user" : "chat-bubble--ai")">
                                @if (message.IsUser)
                                {
                                    <div>@message.Text</div>
                                }
                                else
                                {
                                    <div class="markdown-body">@ToMarkup(message.Text)</div>
                                }
                                <div class="text-muted small mt-1">@message.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                    @if (_isStreaming)
                    {
                        <div class="mb-2 d-flex justify-content-start">
                            <div class="chat-bubble chat-bubble--ai">
                                <div class="markdown-body">@ToMarkup(_streamingResponse.Length > 0 ? _streamingResponse : "…")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-10">
            <input class="form-control"
                   type="text"
                   placeholder="Type a message..."
                   @bind="_inputMessage"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   disabled="@_isStreaming" />
        </div>
        <div class="col-2">
            <button class="btn btn-primary w-100"
                    @onclick="SendMessage"
                    disabled="@(string.IsNullOrWhiteSpace(_inputMessage) || _isStreaming)">
                Send
            </button>
        </div>
    </div>
</div>

